rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // AI jobs — clients read job status + streaming chunks
    // Writes are server-only (Firebase Admin SDK bypasses rules)
    match /ai_jobs/{jobId} {
      allow read: if true;
      allow write: if false;

      match /chunks/{chunkId} {
        allow read: if true;
        allow write: if false;
      }
    }

    // Deny everything else by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
